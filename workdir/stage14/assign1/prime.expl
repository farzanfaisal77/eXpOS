int main(){
    decl
    int n,temp,divisors, iloop;
    enddecl
    begin
    n=1;
    breakpoint;
    while(n<=100) do
        divisors=0;
        iloop=1;
        while(iloop<n)do
            if ((n%iloop) == 0)then
                divisors=divisors+1;
            endif;
            iloop=iloop+1;
        endwhile;
        if (divisors<2) then
            temp=exposcall("Write", -2, n);
        endif;
        n=n+1;
    endwhile;
    return 0;
    end
}