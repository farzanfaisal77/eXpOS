[PROCESS_TABLE + [SYSTEM_STATUS_TABLE+1]*16 + 13]=SP;
SP=[PROCESS_TABLE + [SYSTEM_STATUS_TABLE+1]*16 + 11]*512-1;

backup;

alias reqpid R3;
alias rproc R2;
reqpid=[TERMINAL_STATUS_TABLE+1];
rproc=PROCESS_TABLE+reqpid*16;
[rproc + 8]=P0;

multipush(R3,R2);

R1=9;
R2=reqpid;

call MOD_0;
multipop(R3,R2);
restore;
SP=[PROCESS_TABLE + [SYSTEM_STATUS_TABLE+1]*16 + 13];
ireturn;
